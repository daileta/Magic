{
	"schemaVersion": 1,
	"id": "geckolib",
	"version": "5.4.5",
	"name": "GeckoLib 5",
	"description": "GeckoLib is an animation engine for Minecraft Mods, with support for complex 3D keyframe-based animations, 30+ easings, concurrent animation support, sound and particle keyframes, event keyframes, and more.",
	"authors": [
		"Tslat, Gecko"
	],
	"contributors": [
		"Eliot, AzureDoom, DerToaster, Witixin"
	],
	"contact": {
		"homepage": "https://www.curseforge.com/minecraft/mc-mods/geckolib",
		"issues": "https://github.com/bernie-g/geckolib/issues",
		"sources": "https://github.com/bernie-g/geckolib"
	},
	"license": "MIT",
	"icon": "geckolib.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"software.bernie.geckolib.GeckoLib"
		],
		"client": [
			"software.bernie.geckolib.GeckoLibClient"
		]
	},
	"mixins": [
		"geckolib.mixins.json"
	],
	"accessWidener": "geckolib.classtweaker",
	"depends": {
   		"fabricloader": ">=0.18",
		"fabric-api": ">=0.139.4+1.21.11",
		"java": ">=17",
		"minecraft": ">=1.21.11"
	},
	"custom": {
		"modmenu": {
			"badges": [ "library" ]
		}
	}
}